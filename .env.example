# T28 IO Ring Orchestrator — Runtime Configuration
# Copy this file to .env and fill in your site-specific values.
#   cp .env.example .env
#
# Bridge connection is managed by virtuoso-bridge-lite.
# Configure it once with: virtuoso-bridge init && virtuoso-bridge start
# See README.md > Prerequisites.

# ── Required ────────────────────────────────────────────────────────────────

# Path to your T28 cds.lib (used by Calibre strmout/si wrappers).
# This must be the REMOTE Linux path visible from the compute server.
# Example: /home/youruser/TSMC28/llm_IO/cds.lib
CDS_LIB_PATH_28=/absolute/path/to/your/T28/cds.lib

# ── Filesystem Mode (VB_FS_MODE) ───────────────────────────────────────────
# Controls how files are exchanged between your machine and the compute server.
#
# "shared" — Your workstation and the compute server share an NFS filesystem.
#            Both machines see the same paths. AMS_OUTPUT_ROOT should be a
#            path accessible from the compute server.
#
# "remote" — Your machine (e.g. Windows PC) does NOT share a filesystem with
#            the compute server. Scripts are pushed via SSH to /tmp/vb_t28_calibre/
#            on the remote. After Calibre runs, results are pulled back via SSH.
#            CDS_LIB_PATH_28 should be the REMOTE Linux path to cds.lib.
#
# If VB_FS_MODE is not set, the system auto-detects:
#   - Windows-style local path → "remote"
#   - Probe remote server for AMS_OUTPUT_ROOT → "shared" if accessible
#   - Otherwise → "remote"
#
#VB_FS_MODE=shared
VB_FS_MODE=remote

# ── Output Paths (optional) ────────────────────────────────────────────────
# Resolution order (first set wins):
#   1. AMS_OUTPUT_ROOT         — explicit output root (highest priority)
#   2. AMS_IO_AGENT_PATH/output — workspace root + /output
#   3. $(pwd)/output            — current working directory fallback

# Explicit output root for all generated files.
# On Windows use forward slashes or raw backslashes, e.g.:
#   C:/Users/youruser/project/output
#   C:\\Users\\youruser\\project\\output
AMS_OUTPUT_ROOT=

# Workspace root; scripts use ${AMS_IO_AGENT_PATH}/output when
# AMS_OUTPUT_ROOT is not set. Usually not needed if AMS_OUTPUT_ROOT is set.
#AMS_IO_AGENT_PATH=/absolute/path/to/workspace
